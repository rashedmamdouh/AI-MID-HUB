# Copy this file to backend/.env for local dev.
# On Render, set these in the Dashboard → Environment tab instead.

HF_API_KEY=your_huggingface_key_here
GROQ_API_KEY=your_groq_key_here

EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
VECTOR_STORE_PATH=./rag/vector_store/knowledge_base.index
CHUNKS_STORE_PATH=./rag/vector_store/chunks.json

APP_HOST=0.0.0.0
APP_PORT=8000
